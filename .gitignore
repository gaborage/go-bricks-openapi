# Compiled binary (built by `make build` / `make install`)
/go-bricks-openapi
/go-bricks-openapi.exe

# Cross-compiled release artifacts (`make release-dry-run`)
/go-bricks-openapi-*

# GoReleaser output
/dist/

# Test & coverage artifacts
coverage.out
coverage.html
*.test

# CI gosec scan output (written by the security job's no-op assertion)
gosec-output.txt

# Local generated fixture spec (`make validate-cli` / `make validate-spec`)
.openapi-fixture-spec.yaml

# OS / editor cruft
.DS_Store

# Local agent tooling: the `improve` skill install and Claude Code scratch
# (agent worktrees, skill symlink). Personal/local, not project sources.
/.agents/
/.claude/
/skills-lock.json

# Local implementation-plan scratch (audit output). Landed fixes ship as PRs;
# remaining roadmap items are tracked separately.
/plans/
